{
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/certs/(.*)",
      "dest": "/client/certs/$1"
    },
    {
      "src": "/about-photo.jpg",
      "dest": "/client/about-photo.jpg"
    },
    {
      "src": "/Roy_Heinrich_Delgado_CV.pdf",
      "dest": "/client/Roy_Heinrich_Delgado_CV.pdf"
    },
    {
      "src": "/((?!assets/|certs/|about-photo.jpg|Roy_Heinrich_Delgado_CV.pdf).*)",
      "dest": "api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**"
    }
  }
}
